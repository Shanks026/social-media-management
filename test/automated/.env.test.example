# Copy this file to .env.test and fill in your values
# Never commit .env.test to version control

TEST_BASE_URL=http://localhost:5173

# Agency owner test account
TEST_EMAIL=owner@yourtest.agency
TEST_PASSWORD=YourSecurePassword123!

# Team member test account (for multi-tenant tests)
TEST_TEAM_EMAIL=member@yourtest.agency
TEST_TEAM_PASSWORD=MemberPassword123!

# Supabase credentials (service role key for direct DB seeding)
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhb...your-service-role-key
